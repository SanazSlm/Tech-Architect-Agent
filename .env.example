OPENAI_API_KEY=replace-with-your-openai-api-key

# Optional: full URL only (scheme + host). Wrong values cause DNS errors (e.g. errno 8).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Skip startup DNS check only if you know what you're doing (misconfigured URLs won't be caught early).
# TECH_ARCHITECT_SKIP_OPENAI_DNS_CHECK=0

# Retries for rate limits and transient connection/timeout errors (embeddings + chat).
# TECH_ARCHITECT_API_MAX_ATTEMPTS=10

# Optional model overrides:
# TECH_ARCHITECT_MODEL=gpt-4.1
# TECH_ARCHITECT_EMBEDDING_MODEL=text-embedding-3-small

# Optional embedding chunk sizing (stay under OpenAI 8192-token per-input limit):
# TECH_ARCHITECT_EMBED_CHUNK_CHARS=6000
# TECH_ARCHITECT_EMBED_MAX_CHARS=6000
